      <column caption='% vegetal protien' datatype='real' name='[Calculation_2111805676785696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Daily caloric intake per person that comes from vegetal protein]*100/[Calculation_2111805662822400]' />
      </column>
      <column caption='food efficiency score' datatype='real' name='[Calculation_2942075097243648]' role='measure' type='quantitative'>
