      <column caption='% carbohydrates' datatype='real' name='[Calculation_2111805676605470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Daily caloric intake per person from carbohydrates]*100&#10;/[Calculation_2111805662822400]' />
