      <column caption='% animal protien' datatype='real' name='[Calculation_2111805676498973]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Daily caloric intake per person that comes from animal protein]*100/[Calculation_2111805662822400]' />
